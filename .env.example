# Public site URL used for SEO metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cache duration for upstream news/API requests. Keeps the site fast and avoids rate limits.
NEWS_CACHE_SECONDS=600

# Trusted news API keys. These keys stay server-side and are never exposed to browser code.
NEWSAPI_KEY=
GNEWS_API_KEY=
GUARDIAN_API_KEY=
NYT_API_KEY=
MEDIASTACK_KEY=

# Additional trusted RSS feeds as JSON. Only add reviewed, traceable sources.
# Example:
# TRUSTED_RSS_FEEDS=[{"name":"Example Official Feed","url":"https://example.gov/feed.xml","homepage":"https://example.gov","region":"india","kind":"official","categories":["Government policy"],"reputation":92}]
TRUSTED_RSS_FEEDS=

# Required AI endpoint secret. Keep this server-side and never expose it in frontend code.
# The app uses NVIDIA NIM only: https://integrate.api.nvidia.com/v1/chat/completions
# Model is fixed in code: nvidia/llama-3.1-nemotron-70b-instruct
# AI is only used to summarize/analyze source-backed article metadata, never to create news.
NVIDIA_API_KEY=
